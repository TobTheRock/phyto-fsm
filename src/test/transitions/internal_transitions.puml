@startuml InternalTransitions

[*] --> StateA

StateA : entry / EnterStateA
StateA : exit / ExitStateA
' Internal transition, will not cause exit and re-entry of the state
StateA : InternalEvent / HandleInternalEvent

' Self transition causes exit and re-entry of the state
StateA -> StateA : SelfTransitionEvent / HandleSelfTransitionEvent
StateA -> StateB : GoToB

state StateB {
  [*] --> StateBA
  StateB : entry / EnterStateB
  StateB : exit / ExitStateB
  ' Internal transition, will not cause exit and re-entry of the parent state
  StateBA : InternalEvent / HandleInternalEvent
  ' Self transition causes exit and re-entry of the state
  StateBA -> StateBA : SelfTransitionEvent / HandleSelfTransitionEvent
}

@enduml

